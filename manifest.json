{
  "manifest_version": 3,
  "name": "Header Modifier",
  "version": "1.0",
  "permissions": [
    "<all_urls>",
    "webRequest",
    "webRequestBlocking",
    "activeTab",
    "declarativeNetRequest"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "/dist/background.js",
    "persistent": true
  },
  "action": {
    "default_popup": "popup.html"
  }
}
