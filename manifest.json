{
  "manifest_version": 3,
  "name": "ferheader",
  "version": "1.1.0",
  "permissions": [
    "webRequest",
    "activeTab",
    "declarativeNetRequest",
    "storage",
    "commands"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "/dist/background.js"
  },
  "commands": {
    "do-something": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Do something when F2 is pressed"
    }
  },
"icons": {
    "16": "assets/enabled-16.png",
    "32": "assets/enabled-32.png",
    "48": "assets/enabled-48.png",
    "128": "assets/enabled-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/disabled-16.png",
      "24": "assets/disabled-24.png",
      "32": "assets/disabled-32.png"
    }
  }
}
