{
  "manifest_version": 3,
  "name": "ferheader",
  "version": "1.0",
  "permissions": [
    "webRequest",
    "activeTab",
    "declarativeNetRequest",
    "storage",
    "commands"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "/dist/background.js"
  },
  "commands": {
    "do-something": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Do something when F2 is pressed"
    }
  },
"icons": {
    "16": "assets/disabled-16.png",
    "48": "assets/disabled-48.png",
    "128": "assets/disabled-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
