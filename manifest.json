{
  "manifest_version": 3,
  "name": "ferheader",
  "version": "1.0",
  "permissions": [
    "webRequest",
    "activeTab",
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "/dist/background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
